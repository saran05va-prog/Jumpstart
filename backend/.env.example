# Copy this file to .env and fill in real values before running
# `docker compose up` or deploying to Railway / Render / any host.

# --- Spring profile ---------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# --- Server ------------------------------------------------------------------
PORT=8090

# --- Database (MySQL / Aiven MySQL) ------------------------------------------
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_NAME=jumpstart
DB_USERNAME=jumpstart
DB_PASSWORD=your-secure-db-password

# --- JWT ----------------------------------------------------------------------
# Generate a strong secret, e.g.: openssl rand -base64 64
# WARNING: Use a different secret in each environment!
JWT_SECRET=your-64-character-base64-encoded-jwt-secret-here
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- CORS ----------------------------------------------------------------------
# Comma-separated list of origins allowed to call this API (your frontend URL/s)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- MySQL root password, used only by the docker-compose `db` service --------
MYSQL_ROOT_PASSWORD=your-secure-mysql-root-password
