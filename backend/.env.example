# Copy this file to .env and fill in real values before running
# `docker compose up` or deploying to Railway / Render / any host.

# --- Spring profile ---------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# --- Server ------------------------------------------------------------------
PORT=8090

# --- Database (MySQL) --------------------------------------------------------
# Railway MySQL plugin provides these automatically.
# For local dev: set these to your local MySQL instance.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jumpstart
DB_USERNAME=jumpstart
DB_PASSWORD=jumpstart
DB_POOL_SIZE=10

# --- JWT ----------------------------------------------------------------------
# Generate a strong secret, e.g.: openssl rand -base64 64
# WARNING: Use a different secret in each environment!
JWT_SECRET=your-64-character-base64-encoded-jwt-secret-here

# --- CORS ----------------------------------------------------------------------
# Comma-separated list of origins allowed to call this API (your frontend URL/s)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- MySQL root password, used only by the docker-compose `db` service --------
MYSQL_ROOT_PASSWORD=rootpassword
