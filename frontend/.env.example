# Base URL of the Jumpstart backend API.
# For production (Vercel): set to your Railway backend URL.
# For local development: set to http://localhost:8081/api (Docker) or http://localhost:8090/api.
# VITE_API_URL is read at build time. Set it in Vercel/Railway dashboard or in .env.local.
VITE_API_URL=https://jumpstart-production.up.railway.app/api
